# Copy to .env and fill in. Never commit your real .env file.

# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# PostHog — get from https://us.posthog.com/project/_/settings/project
# iOS app reads these from the Xcode scheme's Run environment variables (see DEVKAT.xcscheme).
POSTHOG_PROJECT_TOKEN=phc_...
POSTHOG_HOST=https://us.i.posthog.com

# PostHog — web app (Vite). Same project token as iOS; VITE_ prefix is required
# for Vite to expose the var to the browser. Set in `web/.env.local` for dev and
# in Vercel project settings for production.
VITE_POSTHOG_PROJECT_TOKEN=phc_...
VITE_POSTHOG_HOST=https://us.i.posthog.com
